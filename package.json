{
  "name": "json-replace",
  "version": "2.0.0",
  "description": "GitHub Action that performs value replacements on JSON objects",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "prepare": "ncc build index.js -o dist --source-map --license licenses.txt",
    "test": "jest",
    "all": "npm run lint && npm run prepare && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beards-and-binary/json-replace.git"
  },
  "keywords": [
    "GitHub",
    "Actions",
    "JSON"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/beards-and-binary/json-replace/issues"
  },
  "homepage": "https://github.com/beards-and-binary/json-replace#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@actions/core": "^1.11.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.0.3",
    "jest": "^30.3.0"
  }
}
