{
  "name": "json-replace",
  "version": "3.0.0",
  "description": "GitHub Action that performs value replacements on JSON objects",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "prepare": "rollup -c",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "all": "npm run lint && npm run prepare && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beards-and-binary/json-replace.git"
  },
  "keywords": [
    "GitHub",
    "Actions",
    "JSON"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/beards-and-binary/json-replace/issues"
  },
  "homepage": "https://github.com/beards-and-binary/json-replace#readme",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@actions/core": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "eslint": "^10.0.3",
    "jest": "^30.3.0",
    "rollup": "^4.60.0"
  }
}
